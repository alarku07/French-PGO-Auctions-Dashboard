# Docker environment configuration template
# Copy this file to .env.docker and fill in your values
# cp .env.docker.example .env.docker

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=pgo
POSTGRES_PASSWORD=secret
POSTGRES_DB=pgo_auctions

# ── Backend database URL (uses postgres container hostname) ─────────────────
DATABASE_URL=postgresql+asyncpg://pgo:secret@postgres:5432/pgo_auctions

# ── External data source ────────────────────────────────────────────────────
EEX_BASE_URL=https://www.eex.com

# ── Sync scheduler ──────────────────────────────────────────────────────────
SYNC_ENABLED=false
SYNC_SCHEDULE_HOUR=6
SYNC_SCHEDULE_MINUTE=0

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS (set to http://localhost for Docker; http://localhost:5173 for local dev)
CORS_ORIGINS=http://localhost

# ── API server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
