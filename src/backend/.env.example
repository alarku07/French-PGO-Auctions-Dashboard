# Required: PostgreSQL connection string (async driver)
# For development: postgresql+asyncpg://user:pass@localhost:5432/pgo_auctions
# For POC/mock-up only: sqlite+aiosqlite:///./pgo_auctions.db
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pgo_auctions

# EEX website base URL (override for testing)
EEX_BASE_URL=https://www.eex.com

# Automatic daily sync
SYNC_ENABLED=true
SYNC_SCHEDULE_HOUR=6
SYNC_SCHEDULE_MINUTE=0

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Backend server
HOST=0.0.0.0
PORT=8000
